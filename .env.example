# ── Nurse Application Cockpit — environment ───────────────────────────────────
# Copy to `.env` and adjust. The app ships with safe DEV defaults so it runs
# without any of these set; production MUST set real secrets.

# Database (SQLite for local dev; swap for a Postgres URL in production).
# Path is relative to prisma/schema.prisma → the db file lives at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Operator login. One seat by design. Dev default password is "cockpit-dev".
OPERATOR_PASSWORD="cockpit-dev"

# Signs the operator session cookie (>= 32 chars). CHANGE IN PRODUCTION.
SESSION_SECRET="dev-only-session-secret-change-me-please-32+chars"

# Master key for encrypting documents + the credential vault at rest.
# Any string; it is run through scrypt. CHANGE IN PRODUCTION and back it up —
# losing it makes every encrypted document and credential unrecoverable.
APP_ENCRYPTION_KEY="dev-only-encryption-key-change-me-in-production"

# Anthropic — AI features (ranking, sponsorship, tailoring, verification).
# OPTIONAL: without a key the app falls back to the deterministic heuristic
# classifier and clearly-labelled stub outputs, so the cockpit stays runnable.
ANTHROPIC_API_KEY=""

# Model aliases (bare aliases per DESIGN.md §4).
ANTHROPIC_MODEL_SONNET="claude-sonnet-4-6"
ANTHROPIC_MODEL_HAIKU="claude-haiku-4-5"
